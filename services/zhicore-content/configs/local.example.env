# zhicore-content local example configuration.
# Copy values into your local env manager and replace every change-me value.

ZHICORE_CONTENT_POSTGRES_DSN=postgres://content:change-me@127.0.0.1:5432/zhicore_content?sslmode=disable
ZHICORE_CONTENT_MONGO_URI=mongodb://content:change-me@127.0.0.1:27017
ZHICORE_CONTENT_REDIS_ADDR=127.0.0.1:6379
# ZHICORE_CONTENT_REDIS_USERNAME=change-me
# ZHICORE_CONTENT_REDIS_PASSWORD=change-me
ZHICORE_CONTENT_REDIS_DB=0
ZHICORE_CONTENT_REDIS_DIAL_TIMEOUT=200ms
ZHICORE_CONTENT_REDIS_READ_TIMEOUT=200ms
ZHICORE_CONTENT_REDIS_WRITE_TIMEOUT=200ms
ZHICORE_CONTENT_REDIS_POOL_SIZE=10
ZHICORE_CONTENT_RABBITMQ_URL=amqp://content:change-me@127.0.0.1:5672/
ZHICORE_CONTENT_RABBITMQ_EXCHANGE=zhicore.events
ZHICORE_CONTENT_RABBITMQ_PUBLISH_CONFIRM_TIMEOUT=3s
ZHICORE_CONTENT_USER_SERVICE_BASE_URL=http://127.0.0.1:18081
ZHICORE_CONTENT_FILE_SERVICE_BASE_URL=http://127.0.0.1:18082

ZHICORE_CONTENT_RESILIENCE_POSTGRES_POST_COMMAND_TX_TIMEOUT=3s
ZHICORE_CONTENT_RESILIENCE_POSTGRES_POST_COMMAND_TX_MAX_ATTEMPTS=1
ZHICORE_CONTENT_RESILIENCE_POSTGRES_POST_COMMAND_TX_MAX_IN_FLIGHT=20
ZHICORE_CONTENT_RESILIENCE_POSTGRES_POST_QUERY_TIMEOUT=2s
ZHICORE_CONTENT_RESILIENCE_POSTGRES_POST_QUERY_MAX_ATTEMPTS=2
ZHICORE_CONTENT_RESILIENCE_POSTGRES_POST_QUERY_MAX_IN_FLIGHT=20
ZHICORE_CONTENT_RESILIENCE_POSTGRES_ENGAGEMENT_QUERY_TIMEOUT=500ms
ZHICORE_CONTENT_RESILIENCE_POSTGRES_ENGAGEMENT_QUERY_MAX_ATTEMPTS=1
ZHICORE_CONTENT_RESILIENCE_POSTGRES_ENGAGEMENT_QUERY_MAX_IN_FLIGHT=5
ZHICORE_CONTENT_RESILIENCE_MONGO_BODY_WRITE_DRAFT_TIMEOUT=5s
ZHICORE_CONTENT_RESILIENCE_MONGO_BODY_WRITE_DRAFT_MAX_ATTEMPTS=2
ZHICORE_CONTENT_RESILIENCE_MONGO_BODY_WRITE_DRAFT_MAX_IN_FLIGHT=10
ZHICORE_CONTENT_RESILIENCE_MONGO_BODY_WRITE_SNAPSHOT_TIMEOUT=5s
ZHICORE_CONTENT_RESILIENCE_MONGO_BODY_WRITE_SNAPSHOT_MAX_ATTEMPTS=2
ZHICORE_CONTENT_RESILIENCE_MONGO_BODY_WRITE_SNAPSHOT_MAX_IN_FLIGHT=5
ZHICORE_CONTENT_RESILIENCE_MONGO_BODY_READ_PUBLISHED_TIMEOUT=3s
ZHICORE_CONTENT_RESILIENCE_MONGO_BODY_READ_PUBLISHED_MAX_ATTEMPTS=2
ZHICORE_CONTENT_RESILIENCE_MONGO_BODY_READ_PUBLISHED_MAX_IN_FLIGHT=20
ZHICORE_CONTENT_RESILIENCE_REDIS_RATE_LIMIT_CHECK_TIMEOUT=200ms
ZHICORE_CONTENT_RESILIENCE_REDIS_RATE_LIMIT_CHECK_MAX_ATTEMPTS=1
ZHICORE_CONTENT_RESILIENCE_REDIS_RATE_LIMIT_CHECK_MAX_IN_FLIGHT=20
ZHICORE_CONTENT_RESILIENCE_REDIS_POST_CACHE_TIMEOUT=200ms
ZHICORE_CONTENT_RESILIENCE_REDIS_POST_CACHE_MAX_ATTEMPTS=1
ZHICORE_CONTENT_RESILIENCE_REDIS_POST_CACHE_MAX_IN_FLIGHT=20
ZHICORE_CONTENT_RESILIENCE_REDIS_ENGAGEMENT_CACHE_TIMEOUT=200ms
ZHICORE_CONTENT_RESILIENCE_REDIS_ENGAGEMENT_CACHE_MAX_ATTEMPTS=1
ZHICORE_CONTENT_RESILIENCE_REDIS_ENGAGEMENT_CACHE_MAX_IN_FLIGHT=20
ZHICORE_CONTENT_RESILIENCE_USER_SERVICE_PROFILE_GET_SUMMARY_TIMEOUT=3s
ZHICORE_CONTENT_RESILIENCE_USER_SERVICE_PROFILE_GET_SUMMARY_MAX_ATTEMPTS=2
ZHICORE_CONTENT_RESILIENCE_USER_SERVICE_PROFILE_GET_SUMMARY_MAX_IN_FLIGHT=20
ZHICORE_CONTENT_RESILIENCE_UPLOAD_SERVICE_FILE_VALIDATE_REF_TIMEOUT=3s
ZHICORE_CONTENT_RESILIENCE_UPLOAD_SERVICE_FILE_VALIDATE_REF_MAX_ATTEMPTS=2
ZHICORE_CONTENT_RESILIENCE_UPLOAD_SERVICE_FILE_VALIDATE_REF_MAX_IN_FLIGHT=20
ZHICORE_CONTENT_RESILIENCE_UPLOAD_SERVICE_FILE_RESOLVE_URL_TIMEOUT=2s
ZHICORE_CONTENT_RESILIENCE_UPLOAD_SERVICE_FILE_RESOLVE_URL_MAX_ATTEMPTS=2
ZHICORE_CONTENT_RESILIENCE_UPLOAD_SERVICE_FILE_RESOLVE_URL_MAX_IN_FLIGHT=20
ZHICORE_CONTENT_RESILIENCE_RABBITMQ_OUTBOX_PUBLISH_TIMEOUT=3s
ZHICORE_CONTENT_RESILIENCE_RABBITMQ_OUTBOX_PUBLISH_MAX_ATTEMPTS=5
ZHICORE_CONTENT_RESILIENCE_RABBITMQ_OUTBOX_PUBLISH_MAX_IN_FLIGHT=5

ZHICORE_CONTENT_HTTP_ADDR=:8080
ZHICORE_CONTENT_HTTP_READ_HEADER_TIMEOUT=2s
ZHICORE_CONTENT_HTTP_READ_TIMEOUT=5s
ZHICORE_CONTENT_HTTP_WRITE_TIMEOUT=10s
ZHICORE_CONTENT_HTTP_IDLE_TIMEOUT=60s
ZHICORE_CONTENT_HTTP_SHUTDOWN_TIMEOUT=20s
ZHICORE_CONTENT_HTTP_MAX_JSON_BODY=1MiB

ZHICORE_CONTENT_RATE_LIMIT_PUBLIC_READ_LIMIT=120
ZHICORE_CONTENT_RATE_LIMIT_PUBLIC_READ_WINDOW=1m
ZHICORE_CONTENT_RATE_LIMIT_PUBLIC_READ_FALLBACK=local_memory
ZHICORE_CONTENT_RATE_LIMIT_PUBLIC_READ_FALLBACK_WINDOW=2m
ZHICORE_CONTENT_RATE_LIMIT_PUBLIC_READ_FAIL_CLOSED=false
ZHICORE_CONTENT_RATE_LIMIT_DRAFT_WRITE_LIMIT=30
ZHICORE_CONTENT_RATE_LIMIT_DRAFT_WRITE_WINDOW=1m
ZHICORE_CONTENT_RATE_LIMIT_DRAFT_WRITE_FALLBACK=local_memory
ZHICORE_CONTENT_RATE_LIMIT_DRAFT_WRITE_FALLBACK_WINDOW=30s
ZHICORE_CONTENT_RATE_LIMIT_DRAFT_WRITE_FAIL_CLOSED=false
ZHICORE_CONTENT_RATE_LIMIT_PUBLISH_LIFECYCLE_LIMIT=5
ZHICORE_CONTENT_RATE_LIMIT_PUBLISH_LIFECYCLE_WINDOW=1m
ZHICORE_CONTENT_RATE_LIMIT_PUBLISH_LIFECYCLE_FALLBACK=none
ZHICORE_CONTENT_RATE_LIMIT_PUBLISH_LIFECYCLE_FAIL_CLOSED=true
ZHICORE_CONTENT_RATE_LIMIT_ENGAGEMENT_WRITE_LIMIT=60
ZHICORE_CONTENT_RATE_LIMIT_ENGAGEMENT_WRITE_WINDOW=1m
ZHICORE_CONTENT_RATE_LIMIT_ENGAGEMENT_WRITE_FALLBACK=local_memory
ZHICORE_CONTENT_RATE_LIMIT_ENGAGEMENT_WRITE_FALLBACK_WINDOW=30s
ZHICORE_CONTENT_RATE_LIMIT_ENGAGEMENT_WRITE_FAIL_CLOSED=false
ZHICORE_CONTENT_RATE_LIMIT_ENGAGEMENT_READ_LIMIT=120
ZHICORE_CONTENT_RATE_LIMIT_ENGAGEMENT_READ_WINDOW=1m
ZHICORE_CONTENT_RATE_LIMIT_ENGAGEMENT_READ_FALLBACK=local_memory
ZHICORE_CONTENT_RATE_LIMIT_ENGAGEMENT_READ_FALLBACK_WINDOW=2m
ZHICORE_CONTENT_RATE_LIMIT_ENGAGEMENT_READ_FAIL_CLOSED=false
ZHICORE_CONTENT_RATE_LIMIT_ADMIN_COMMAND_LIMIT=10
ZHICORE_CONTENT_RATE_LIMIT_ADMIN_COMMAND_WINDOW=1m
ZHICORE_CONTENT_RATE_LIMIT_ADMIN_COMMAND_FALLBACK=none
ZHICORE_CONTENT_RATE_LIMIT_ADMIN_COMMAND_FAIL_CLOSED=true
ZHICORE_CONTENT_RATE_LIMIT_INTERNAL_CLIENT_LIMIT=120
ZHICORE_CONTENT_RATE_LIMIT_INTERNAL_CLIENT_WINDOW=1m
ZHICORE_CONTENT_RATE_LIMIT_INTERNAL_CLIENT_FALLBACK=none
ZHICORE_CONTENT_RATE_LIMIT_INTERNAL_CLIENT_FAIL_CLOSED=true

ZHICORE_CONTENT_WORKERS_CLEANUP_ENABLED=false
ZHICORE_CONTENT_WORKERS_REPAIR_ENABLED=false
ZHICORE_CONTENT_WORKERS_OUTBOX_ENABLED=false
ZHICORE_CONTENT_WORKERS_ENGAGEMENT_STATS_ENABLED=false
