<mxfile host="app.diagrams.net" modified="2026-06-26T00:00:00.000Z" agent="Codex" version="30.0.2" type="device">
  <diagram id="gateway-workflow" name="Gateway 请求认证 + 路由流程">
    <mxGraphModel dx="2200" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2200" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="title" value="Gateway 请求认证 + 路由流程&#xa;目标设计 / planned；具体业务流程图" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=26;fontStyle=1;fontColor=#0f172a;" vertex="1" parent="1"><mxGeometry x="40" y="30" width="1400" height="70" as="geometry"/></mxCell>
        <mxCell id="legend" value="Legend：蓝=handler/API；绿=application/domain；灰=DB/持久化；橙=外部事实/基础设施；紫=异步 consumer；黄=判断/guard；红=blocker。" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#f97316;fontSize=12;align=left;verticalAlign=top;spacing=8;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="1590" y="30" width="520" height="90" as="geometry"/></mxCell>
        <mxCell id="n1" value="前端请求&#xa;旧 API path/header/body" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="1"><mxGeometry x="40" y="170" width="240" height="92" as="geometry"/></mxCell>
        <mxCell id="n2" value="Gateway handler/middleware&#xa;解析 requestId、auth header" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="1"><mxGeometry x="350" y="160" width="270" height="110" as="geometry"/></mxCell>
        <mxCell id="d1" value="路由是否匹配？" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;spacing=6;" vertex="1" parent="1"><mxGeometry x="690" y="155" width="180" height="120" as="geometry"/></mxCell>
        <mxCell id="b1" value="404 route not found&#xa;不触达下游服务" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="1"><mxGeometry x="690" y="335" width="230" height="95" as="geometry"/></mxCell>
        <mxCell id="n3" value="认证/限流/权限 gate&#xa;JWT 校验、角色上下文" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="1"><mxGeometry x="960" y="145" width="260" height="125" as="geometry"/></mxCell>
        <mxCell id="d2" value="gate 是否通过？" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;spacing=6;" vertex="1" parent="1"><mxGeometry x="1280" y="155" width="180" height="120" as="geometry"/></mxCell>
        <mxCell id="b2" value="401/403/429&#xa;不转发、不写业务状态" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="1"><mxGeometry x="1280" y="335" width="240" height="95" as="geometry"/></mxCell>
        <mxCell id="n4" value="反向代理 / typed client&#xa;转发到目标 service" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffedd5;strokeColor=#ea580c;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="1"><mxGeometry x="1540" y="145" width="290" height="125" as="geometry"/></mxCell>
        <mxCell id="n5" value="下游 service handler&#xa;保持旧前端 API 形态" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede9fe;strokeColor=#7c3aed;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="1"><mxGeometry x="1880" y="150" width="270" height="110" as="geometry"/></mxCell>
        <mxCell id="note" value="关键约束&#xa;Gateway 不拥有业务数据；只能路由、鉴权、限流和环境切换。" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#f97316;fontSize=12;align=left;verticalAlign=top;spacing=8;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="40" y="370" width="450" height="135" as="geometry"/></mxCell>
        <mxCell id="e1" value="HTTP" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#334155;strokeWidth=2;" edge="1" parent="1" source="n1" target="n2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" value="match" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#334155;strokeWidth=2;" edge="1" parent="1" source="n2" target="d1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" value="no" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#dc2626;strokeWidth=2;" edge="1" parent="1" source="d1" target="b1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e4" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#16a34a;strokeWidth=2;" edge="1" parent="1" source="d1" target="n3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e5" value="guard" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#334155;strokeWidth=2;" edge="1" parent="1" source="n3" target="d2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e6" value="fail" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#dc2626;strokeWidth=2;" edge="1" parent="1" source="d2" target="b2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e7" value="pass" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#16a34a;strokeWidth=2;" edge="1" parent="1" source="d2" target="n4"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e8" value="forward" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#334155;strokeWidth=2;" edge="1" parent="1" source="n4" target="n5"><mxGeometry relative="1" as="geometry"/></mxCell>
