<mxfile host="app.diagrams.net" modified="2026-06-26T00:00:00.000Z" agent="Codex" version="30.0.2" type="device">
  <diagram id="content-workflow" name="Content 发布文章 + 搜索/排行/通知异步流程">
    <mxGraphModel dx="2200" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2200" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="title" value="Content 发布文章 + 搜索/排行/通知异步流程&#xa;目标设计 / planned；具体业务流程图" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=26;fontStyle=1;fontColor=#0f172a;" vertex="1" parent="1"><mxGeometry x="40" y="30" width="1400" height="70" as="geometry"/></mxCell>
        <mxCell id="legend" value="Legend：蓝=handler/API；绿=application/domain；灰=DB/持久化；橙=外部事实/基础设施；紫=异步 consumer；黄=判断/guard；红=blocker。" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#f97316;fontSize=12;align=left;verticalAlign=top;spacing=8;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="1590" y="30" width="520" height="90" as="geometry"/></mxCell>
        <mxCell id="n1" value="POST /posts/publish&#xa;Handler 解析 meta/body/tags" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="1"><mxGeometry x="40" y="170" width="230" height="92" as="geometry"/></mxCell>
        <mxCell id="n2" value="PublishPost application&#xa;编排 Post lifecycle saga" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="1"><mxGeometry x="330" y="165" width="240" height="100" as="geometry"/></mxCell>
        <mxCell id="n3" value="Mongo body store&#xa;保存正文/草稿快照" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffedd5;strokeColor=#ea580c;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="1"><mxGeometry x="620" y="80" width="230" height="100" as="geometry"/></mxCell>
        <mxCell id="d1" value="正文和发布规则&#xa;是否满足？" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;spacing=6;" vertex="1" parent="1"><mxGeometry x="620" y="250" width="190" height="125" as="geometry"/></mxCell>
        <mxCell id="b1" value="blocked/compensate&#xa;正文失败或状态非法&#xa;进入可恢复补偿" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="1"><mxGeometry x="900" y="270" width="240" height="110" as="geometry"/></mxCell>
        <mxCell id="n4" value="PostgreSQL transaction&#xa;posts 状态=published&#xa;post_tags/category refs&#xa;outbox_event(content.post.published)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f1f5f9;strokeColor=#64748b;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="1"><mxGeometry x="900" y="100" width="320" height="150" as="geometry"/></mxCell>
        <mxCell id="n5" value="提交后&#xa;删除文章详情/列表缓存&#xa;返回 publicPostId" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffedd5;strokeColor=#ea580c;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="1"><mxGeometry x="1280" y="120" width="250" height="110" as="geometry"/></mxCell>
        <mxCell id="n6" value="Outbox dispatcher&#xa;发布 content.post.published" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede9fe;strokeColor=#7c3aed;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="1"><mxGeometry x="910" y="480" width="270" height="105" as="geometry"/></mxCell>
        <mxCell id="n7" value="Search consumer&#xa;upsert ES index" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede9fe;strokeColor=#7c3aed;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="1"><mxGeometry x="600" y="480" width="230" height="100" as="geometry"/></mxCell>
        <mxCell id="n8" value="Ranking consumer&#xa;写 ledger/bucket" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede9fe;strokeColor=#7c3aed;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="1"><mxGeometry x="330" y="480" width="230" height="100" as="geometry"/></mxCell>
        <mxCell id="n9" value="Notification consumer&#xa;作者订阅/campaign 通知" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede9fe;strokeColor=#7c3aed;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="1"><mxGeometry x="60" y="480" width="230" height="100" as="geometry"/></mxCell>
        <mxCell id="note" value="关键约束&#xa;Post 聚合不承载浏览/点赞/收藏/评论高频计数。&#xa;Search/Ranking/Notification 通过事件消费发布事实。" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#f97316;fontSize=12;align=left;verticalAlign=top;spacing=8;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="40" y="330" width="430" height="135" as="geometry"/></mxCell>
        <mxCell id="e1" value="DTO" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#334155;strokeWidth=2;" edge="1" parent="1" source="n1" target="n2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" value="write body" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#334155;strokeWidth=2;" edge="1" parent="1" source="n2" target="n3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" value="body ok" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#334155;strokeWidth=2;" edge="1" parent="1" source="n3" target="d1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e4" value="fail" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#dc2626;strokeWidth=2;" edge="1" parent="1" source="d1" target="b1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e5" value="pass" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#16a34a;strokeWidth=2;" edge="1" parent="1" source="d1" target="n4"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e6" value="commit" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#16a34a;strokeWidth=2;" edge="1" parent="1" source="n4" target="n5"><mxGeometry relative="1" as="geometry"/></mxCell>
