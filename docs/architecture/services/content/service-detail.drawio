<mxfile host="app.diagrams.net" modified="2026-06-26T00:00:00.000Z" agent="Codex" version="30.0.2" type="device">
  <diagram id="content-publish-workflow" name="Content 保存草稿与发布原子切换流程">
    <mxGraphModel dx="2400" dy="1350" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2400" pageHeight="1350" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="title" value="Content 保存草稿与发布原子切换流程&#xa;目标设计 / planned；具名用例：SaveDraft + PublishPost" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=26;fontStyle=1;fontColor=#0f172a;" vertex="1" parent="1"><mxGeometry x="40" y="30" width="1500" height="80" as="geometry"/></mxCell>
        <mxCell id="legend" value="Legend&#xa;蓝=API/handler&#xa;绿=application/domain owner&#xa;灰=PG/Mongo 持久化&#xa;橙=外部 facts/基础设施&#xa;紫=异步 worker/consumer&#xa;黄=guard/判断&#xa;红=blocker/事故" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#f97316;fontSize=12;align=left;verticalAlign=top;spacing=8;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="1900" y="30" width="430" height="150" as="geometry"/></mxCell>

        <mxCell id="draft-entry" value="PUT /posts/{id}/draft&#xa;Handler 解析 meta/blocks&#xa;base_post_version/base_draft_hash" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="1"><mxGeometry x="40" y="170" width="260" height="115" as="geometry"/></mxCell>
        <mxCell id="draft-app" value="SaveDraft application&#xa;校验 owner/status&#xa;调用 BodyParserRegistry" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=13;fontStyle=1;align=left;verticalAlign=middle;spacing=8;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="350" y="165" width="285" height="125" as="geometry"/></mxCell>
        <mxCell id="schema-guard" value="blocks schema/hash&#xa;是否有效？" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;spacing=6;" vertex="1" parent="1"><mxGeometry x="690" y="160" width="190" height="125" as="geometry"/></mxCell>
        <mxCell id="schema-blocker" value="BODY_SCHEMA_INVALID&#xa;路径级 details&#xa;code/messageKey i18n" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="1"><mxGeometry x="690" y="330" width="230" height="115" as="geometry"/></mxCell>
        <mxCell id="mongo-draft" value="MongoDB post_bodies&#xa;写 new draft body UUID&#xa;canonical blocks/plain_text/hash" style="shape=cylinder;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#f1f5f9;strokeColor=#64748b;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="1"><mxGeometry x="960" y="145" width="285" height="145" as="geometry"/></mxCell>
        <mxCell id="pg-draft-tx" value="PostgreSQL transaction&#xa;校验 post_version/draft_hash&#xa;切 draft_body_id/hash/size&#xa;写 cleanup old draft" style="shape=cylinder;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#f1f5f9;strokeColor=#64748b;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="1"><mxGeometry x="1320" y="135" width="330" height="165" as="geometry"/></mxCell>
        <mxCell id="draft-conflict" value="DRAFT_CONFLICT&#xa;PG 不切指针&#xa;new draft 成 orphan" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="1"><mxGeometry x="1345" y="340" width="260" height="115" as="geometry"/></mxCell>
        <mxCell id="draft-ok" value="保存成功&#xa;PG.draft_body_id 指向新草稿&#xa;旧 draft 异步清理" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="1"><mxGeometry x="1730" y="155" width="285" height="115" as="geometry"/></mxCell>

        <mxCell id="publish-entry" value="POST /posts/{id}/publish&#xa;Handler 解析 draft_body_id/hash&#xa;base_post_version" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="1"><mxGeometry x="40" y="610" width="270" height="115" as="geometry"/></mxCell>
        <mxCell id="publish-app" value="PublishPost application&#xa;读取 posts draft_*&#xa;owner/status/post_version guard" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=13;fontStyle=1;align=left;verticalAlign=middle;spacing=8;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="360" y="600" width="300" height="135" as="geometry"/></mxCell>
        <mxCell id="draft-exists" value="draft body&#xa;存在且 hash 匹配？" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;spacing=6;" vertex="1" parent="1"><mxGeometry x="720" y="600" width="195" height="130" as="geometry"/></mxCell>
        <mxCell id="repair-task" value="CONTENT_BODY_INCONSISTENT&#xa;阻止发布&#xa;写 repair task + 告警" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="1"><mxGeometry x="700" y="790" width="255" height="125" as="geometry"/></mxCell>
        <mxCell id="publish-rules" value="发布规则是否通过？&#xa;title 必填&#xa;plain_text &gt;= 10&#xa;审核/媒体/封面 guard" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;spacing=6;" vertex="1" parent="1"><mxGeometry x="1010" y="590" width="225" height="150" as="geometry"/></mxCell>
        <mxCell id="publish-blocked" value="发布失败&#xa;POST_TITLE_EMPTY / BODY_TEXT_TOO_SHORT&#xa;COVER_UNAVAILABLE / MEDIA_REF_INVALID" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="1"><mxGeometry x="1000" y="790" width="300" height="130" as="geometry"/></mxCell>
        <mxCell id="upload-facts" value="File facts&#xa;封面非必填&#xa;internal media 校验 file_id/status&#xa;external media 只校验安全格式" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffedd5;strokeColor=#ea580c;fontSize=13;fontStyle=1;align=left;verticalAlign=middle;spacing=8;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="1020" y="1015" width="330" height="135" as="geometry"/></mxCell>
        <mxCell id="mongo-snapshot" value="MongoDB post_bodies&#xa;写 new snapshot body UUID&#xa;不覆盖线上 snapshot" style="shape=cylinder;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#f1f5f9;strokeColor=#64748b;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="1"><mxGeometry x="1320" y="585" width="300" height="150" as="geometry"/></mxCell>
        <mxCell id="pg-publish-tx" value="PostgreSQL transaction&#xa;再次校验 post_version/draft_body_id/hash&#xa;published_* = draft_*&#xa;published_body_id = snapshot&#xa;清空 draft_* + outbox + cleanup" style="shape=cylinder;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#f1f5f9;strokeColor=#64748b;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="1"><mxGeometry x="1710" y="560" width="360" height="190" as="geometry"/></mxCell>
        <mxCell id="publish-conflict" value="DRAFT_CONFLICT&#xa;snapshot 未被 PG 引用&#xa;写 orphan cleanup" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="1"><mxGeometry x="1745" y="820" width="290" height="125" as="geometry"/></mxCell>
        <mxCell id="publish-ok" value="发布成功&#xa;详情页只读 PG.published_body_id&#xa;返回 publicPostId" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="1"><mxGeometry x="2140" y="590" width="245" height="120" as="geometry"/></mxCell>

        <mxCell id="cleanup-worker" value="BodyCleanupWorker&#xa;按 body_id 精确删除&#xa;删除前查 PG 未引用" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede9fe;strokeColor=#7c3aed;fontSize=13;fontStyle=1;align=left;verticalAlign=middle;spacing=8;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="1700" y="1010" width="290" height="125" as="geometry"/></mxCell>
        <mxCell id="repair-worker" value="BodyRepairWorker&#xa;published body miss/hash mismatch&#xa;告警 + 人工/备份修复" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede9fe;strokeColor=#7c3aed;fontSize=13;fontStyle=1;align=left;verticalAlign=middle;spacing=8;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="700" y="1015" width="285" height="125" as="geometry"/></mxCell>
        <mxCell id="outbox-dispatcher" value="Outbox dispatcher&#xa;content.post.published/updated&#xa;事件不带正文全文" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede9fe;strokeColor=#7c3aed;fontSize=13;fontStyle=1;align=left;verticalAlign=middle;spacing=8;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="2140" y="820" width="260" height="120" as="geometry"/></mxCell>
        <mxCell id="search-consumer" value="Search consumer&#xa;按 bodyHash 拉 Content published body&#xa;不可用则重试/DLQ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede9fe;strokeColor=#7c3aed;fontSize=13;fontStyle=1;align=left;verticalAlign=middle;spacing=8;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="2140" y="1010" width="270" height="125" as="geometry"/></mxCell>
        <mxCell id="rank-notify" value="Ranking / Notification&#xa;只消费轻量字段&#xa;不读取正文" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede9fe;strokeColor=#7c3aed;fontSize=13;fontStyle=1;align=left;verticalAlign=middle;spacing=8;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="2140" y="1165" width="270" height="115" as="geometry"/></mxCell>
        <mxCell id="note" value="关键选择与原因&#xa;1. 不做 PG+Mongo 分布式事务：成本高且恢复复杂。&#xa;2. 不采用 PG 先 published 再补 Mongo：正文是核心数据，不能发布后读不到。&#xa;3. PG 指针是可见性真相源；Mongo 只保存 body。&#xa;4. 普通文章不保留历史版本；旧 body 通过 cleanup 清理。&#xa;5. 链接预览第一阶段不做；后续必须后端异步 + SSRF-safe fetcher。" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#f97316;fontSize=12;align=left;verticalAlign=top;spacing=8;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="40" y="1010" width="600" height="210" as="geometry"/></mxCell>

        <mxCell id="e1" value="request" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#334155;strokeWidth=2;" edge="1" parent="1" source="draft-entry" target="draft-app"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" value="parse/canonicalize" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#334155;strokeWidth=2;" edge="1" parent="1" source="draft-app" target="schema-guard"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" value="fail" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#dc2626;strokeWidth=2;" edge="1" parent="1" source="schema-guard" target="schema-blocker"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e4" value="pass" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#16a34a;strokeWidth=2;" edge="1" parent="1" source="schema-guard" target="mongo-draft"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e5" value="new draft UUID" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#334155;strokeWidth=2;" edge="1" parent="1" source="mongo-draft" target="pg-draft-tx"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e6" value="version/hash mismatch" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#dc2626;strokeWidth=2;" edge="1" parent="1" source="pg-draft-tx" target="draft-conflict"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e7" value="commit" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#16a34a;strokeWidth=2;" edge="1" parent="1" source="pg-draft-tx" target="draft-ok"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e8" value="cleanup old draft" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;dashed=1;strokeColor=#7c3aed;strokeWidth=2;" edge="1" parent="1" source="pg-draft-tx" target="cleanup-worker"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1490" y="500"/><mxPoint x="1845" y="500"/></Array></mxGeometry></mxCell>

        <mxCell id="e9" value="request" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#334155;strokeWidth=2;" edge="1" parent="1" source="publish-entry" target="publish-app"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e10" value="load PG + Mongo draft" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#334155;strokeWidth=2;" edge="1" parent="1" source="publish-app" target="draft-exists"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e11" value="fail" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#dc2626;strokeWidth=2;" edge="1" parent="1" source="draft-exists" target="repair-task"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e12" value="pass" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#16a34a;strokeWidth=2;" edge="1" parent="1" source="draft-exists" target="publish-rules"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e13" value="fail" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#dc2626;strokeWidth=2;" edge="1" parent="1" source="publish-rules" target="publish-blocked"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e14" value="read facts" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;dashed=1;strokeColor=#64748b;strokeWidth=2;" edge="1" parent="1" source="publish-rules" target="upload-facts"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e15" value="pass" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#16a34a;strokeWidth=2;" edge="1" parent="1" source="publish-rules" target="mongo-snapshot"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e16" value="new snapshot UUID" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#334155;strokeWidth=2;" edge="1" parent="1" source="mongo-snapshot" target="pg-publish-tx"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e17" value="version/hash mismatch" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#dc2626;strokeWidth=2;" edge="1" parent="1" source="pg-publish-tx" target="publish-conflict"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e18" value="commit" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#16a34a;strokeWidth=2;" edge="1" parent="1" source="pg-publish-tx" target="publish-ok"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e19" value="cleanup old draft/snapshot" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;dashed=1;strokeColor=#7c3aed;strokeWidth=2;" edge="1" parent="1" source="pg-publish-tx" target="cleanup-worker"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e20" value="repair" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;dashed=1;strokeColor=#7c3aed;strokeWidth=2;" edge="1" parent="1" source="repair-task" target="repair-worker"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e21" value="outbox" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;dashed=1;strokeColor=#7c3aed;strokeWidth=2;" edge="1" parent="1" source="pg-publish-tx" target="outbox-dispatcher"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e22" value="pull published body" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;dashed=1;strokeColor=#7c3aed;strokeWidth=2;" edge="1" parent="1" source="outbox-dispatcher" target="search-consumer"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e23" value="light event fields" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;dashed=1;strokeColor=#7c3aed;strokeWidth=2;" edge="1" parent="1" source="outbox-dispatcher" target="rank-notify"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
