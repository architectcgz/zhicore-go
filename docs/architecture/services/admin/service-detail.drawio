<mxfile host="app.diagrams.net" modified="2026-06-26T00:00:00.000Z" agent="Codex" version="30.0.2" type="device">
  <diagram id="admin-workflow" name="Admin 处理举报 + 委托 owner 服务流程">
    <mxGraphModel dx="2200" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2200" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="title" value="Admin 处理举报 + 委托 owner 服务流程&#xa;目标设计 / planned；具体业务流程图" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=26;fontStyle=1;fontColor=#0f172a;" vertex="1" parent="1"><mxGeometry x="40" y="30" width="1400" height="70" as="geometry"/></mxCell>
        <mxCell id="legend" value="Legend：蓝=handler/API；绿=application/domain；灰=DB/持久化；橙=外部事实/基础设施；紫=异步 consumer；黄=判断/guard；红=blocker。" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#f97316;fontSize=12;align=left;verticalAlign=top;spacing=8;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="1590" y="30" width="520" height="90" as="geometry"/></mxCell>
        <mxCell id="n1" value="POST /admin/reports/{id}/review&#xa;Handler 解析 decision/reason" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="1"><mxGeometry x="40" y="170" width="260" height="92" as="geometry"/></mxCell>
        <mxCell id="n2" value="Admin application&#xa;加载管理员权限和举报状态" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="1"><mxGeometry x="360" y="160" width="260" height="110" as="geometry"/></mxCell>
        <mxCell id="d1" value="权限和状态&#xa;是否允许处理？" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;spacing=6;" vertex="1" parent="1"><mxGeometry x="690" y="155" width="190" height="125" as="geometry"/></mxCell>
        <mxCell id="b1" value="blocked&#xa;权限不足/已处理&#xa;不调用 owner 服务" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="1"><mxGeometry x="690" y="340" width="230" height="100" as="geometry"/></mxCell>
        <mxCell id="n3" value="PostgreSQL transaction&#xa;reports 状态更新&#xa;audit_logs 记录完整审计" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f1f5f9;strokeColor=#64748b;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="1"><mxGeometry x="960" y="120" width="310" height="150" as="geometry"/></mxCell>
        <mxCell id="d2" value="需要业务处置？&#xa;删除/禁用/恢复" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;spacing=6;" vertex="1" parent="1"><mxGeometry x="1340" y="140" width="190" height="125" as="geometry"/></mxCell>
        <mxCell id="n4" value="调用 owner service&#xa;Comment/Delete 或 Content/User mutation&#xa;携带 admin context" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffedd5;strokeColor=#ea580c;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="1"><mxGeometry x="1620" y="115" width="310" height="150" as="geometry"/></mxCell>
        <mxCell id="n5" value="更新处理结果&#xa;返回管理端 DTO" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede9fe;strokeColor=#7c3aed;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="1"><mxGeometry x="1620" y="360" width="270" height="110" as="geometry"/></mxCell>
        <mxCell id="b2" value="owner 调用失败&#xa;记录失败，不伪造完成" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="1"><mxGeometry x="1340" y="360" width="230" height="100" as="geometry"/></mxCell>
        <mxCell id="note" value="关键约束&#xa;Admin 保存审核审计；业务状态仍由 User/Content/Comment owner 服务修改。" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#f97316;fontSize=12;align=left;verticalAlign=top;spacing=8;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="40" y="380" width="450" height="135" as="geometry"/></mxCell>
        <mxCell id="e1" value="DTO" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#334155;strokeWidth=2;" edge="1" parent="1" source="n1" target="n2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" value="guard" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#334155;strokeWidth=2;" edge="1" parent="1" source="n2" target="d1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" value="fail" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#dc2626;strokeWidth=2;" edge="1" parent="1" source="d1" target="b1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e4" value="pass" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#16a34a;strokeWidth=2;" edge="1" parent="1" source="d1" target="n3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e5" value="decision" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#334155;strokeWidth=2;" edge="1" parent="1" source="n3" target="d2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e6" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#16a34a;strokeWidth=2;" edge="1" parent="1" source="d2" target="n4"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e7" value="no" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#16a34a;strokeWidth=2;" edge="1" parent="1" source="d2" target="n5"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e8" value="success" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#16a34a;strokeWidth=2;" edge="1" parent="1" source="n4" target="n5"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e9" value="fail" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#dc2626;strokeWidth=2;" edge="1" parent="1" source="n4" target="b2"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
