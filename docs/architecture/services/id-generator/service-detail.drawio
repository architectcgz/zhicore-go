        <mxCell id="n5" value="调用方缓存号段&#xa;本地消耗，耗尽再申请" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffedd5;strokeColor=#ea580c;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="1"><mxGeometry x="1690" y="150" width="260" height="110" as="geometry"/></mxCell>
        <mxCell id="note" value="关键约束&#xa;只为兼容旧 client 或业务编号保留；不要让新服务默认依赖集中发内部主键。" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#f97316;fontSize=12;align=left;verticalAlign=top;spacing=8;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="40" y="390" width="470" height="135" as="geometry"/></mxCell>
        <mxCell id="e1" value="request" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeColor=#334155;strokeWidth=2;" edge="1" parent="1" source="n1" target="n2"><mxGeometry relative="1" as="geometry"/></mxCell>
