  <diagram id="id-generator-workflow" name="ID Generator 号段分配流程">
    <mxGraphModel dx="2200" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2200" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="title" value="ID Generator 号段分配流程&#xa;目标设计 / planned；具体业务流程图" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=26;fontStyle=1;fontColor=#0f172a;" vertex="1" parent="1"><mxGeometry x="40" y="30" width="1400" height="70" as="geometry"/></mxCell>
        <mxCell id="legend" value="Legend：蓝=handler/API；绿=application/domain；灰=DB/持久化；橙=外部事实/基础设施；紫=异步 consumer；黄=判断/guard；红=blocker。" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#f97316;fontSize=12;align=left;verticalAlign=top;spacing=8;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="1590" y="30" width="520" height="90" as="geometry"/></mxCell>
        <mxCell id="n1" value="POST /ids/next 或 /segments&#xa;Handler 解析 bizType/count" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="1"><mxGeometry x="40" y="170" width="260" height="92" as="geometry"/></mxCell>
        <mxCell id="n2" value="IdGenerator application&#xa;校验调用方和业务类型" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="1"><mxGeometry x="360" y="165" width="260" height="105" as="geometry"/></mxCell>
        <mxCell id="d1" value="是否仍需要集中发号？" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;spacing=6;" vertex="1" parent="1"><mxGeometry x="690" y="155" width="190" height="125" as="geometry"/></mxCell>
        <mxCell id="b1" value="blocked/deprecated&#xa;新 Go 服务内部主键&#xa;默认使用本地 DB identity" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="1"><mxGeometry x="690" y="340" width="260" height="105" as="geometry"/></mxCell>
        <mxCell id="n3" value="PostgreSQL transaction&#xa;锁定 sequence/segment 行&#xa;更新 next_value/watermark" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f1f5f9;strokeColor=#64748b;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="1"><mxGeometry x="980" y="120" width="320" height="150" as="geometry"/></mxCell>
